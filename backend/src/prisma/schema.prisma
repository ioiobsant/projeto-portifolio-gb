generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id
  category        String
  model           String
  productImageUrl String?
  size            String?
  customerId      String
  specs           Json
  quantity        Int
  saleValue       Int
  deliveryDate    String
  status          String
  createdAt       String
  notes           String?
  customer        Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

model Customer {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String? @unique
  phone     String  @unique
  createdAt String
  updatedAt String
  orders    Order[]
}

model Admin {
  id               String            @id @default(cuid())
  email            String?           @unique
  phone            String?           @unique
  passwordHash     String
  createdAt        String
  isActive         Boolean           @default(false)
  updatedAt        String            @default("")
  activationTokens ActivationToken[]
  refreshSessions  RefreshSession[]
}

model ActivationToken {
  id         String  @id @default(cuid())
  adminId    String
  tokenHash  String  @unique
  expiresAt  String
  consumedAt String?
  createdAt  String
  admin      Admin   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
}

model RefreshSession {
  id                  String  @id @default(cuid())
  adminId             String
  tokenHash           String  @unique
  csrfTokenHash       String
  userAgent           String?
  ipAddress           String?
  expiresAt           String
  revokedAt           String?
  replacedBySessionId String?
  createdAt           String
  lastUsedAt          String?
  admin               Admin   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@index([revokedAt])
}
