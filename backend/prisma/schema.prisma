generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id
  category        String
  model           String
  productImageUrl String?
  size            String?
  customer        Json     // { name, whatsapp, email }
  specs           Json     // { hasPainting, paintColor?, paintFinish?, fabric?, foam?, base?, manufactureType }
  quantity        Int
  saleValue       Int      // valor em centavos ou inteiro (ex: 18500)
  deliveryDate    String   // ISO date "YYYY-MM-DD"
  status          String
  createdAt       String   // ISO date "YYYY-MM-DD"
  notes           String?
}
