generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id              String   @id
  category        String
  model           String
  productImageUrl String?
  size            String?
  customer        Json
  specs           Json
  quantity        Int
  saleValue       Int
  deliveryDate    String
  status          String
  createdAt       String
  notes           String?
}

model Admin {
  id           String   @id @default(cuid())
  email        String?
  phone        String?
  passwordHash String
  createdAt    String
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  expiresAt  String
}
