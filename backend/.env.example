# SQLite (arquivo local)
DATABASE_URL="file:./dev.sqlite"

# Segredo para assinatura do JWT (obrigatório em produção)
JWT_SECRET="troque-este-segredo"

# Origens permitidas no CORS (separar por virgula)
CORS_ORIGIN="http://localhost:5173"

# Admin único (login apenas com este email)
ADMIN_EMAIL="ioiobsant@gmail.com"
# Hash bcrypt da senha (nunca coloque a senha em texto). Gerar com: node -e "require('bcryptjs').hash('SuaSenha', 12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=""

# Duracao dos tokens/sessoes
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Custo de hash da senha no bcrypt
BCRYPT_SALT_ROUNDS=12

# Porta do servidor (opcional, padrão 3001)
# PORT=3001

# SMTP para envio do token de redefinicao de senha por e-mail
# Use uma App Password do Gmail ou credenciais de outro provedor SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-app-password"
SMTP_FROM="Genice Brandão Atelier <seu-email@gmail.com>"

# WhatsApp Cloud API (Meta)
# A Meta oferece cota gratuita para testes; para produção, consulte as regras vigentes da conta.
WHATSAPP_API_BASE_URL="https://graph.facebook.com"
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_DEFAULT_COUNTRY_CODE="55"
