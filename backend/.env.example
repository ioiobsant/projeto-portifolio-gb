# SQLite (arquivo local)
DATABASE_URL="file:./dev.sqlite"

# Segredo para assinatura do JWT (obrigatório em produção)
JWT_SECRET="troque-este-segredo"

# Origens permitidas no CORS (separar por virgula)
CORS_ORIGIN="http://localhost:5173"

# Duracao dos tokens/sessoes
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
ACTIVATION_TOKEN_TTL_MINUTES=30

# Custo de hash da senha no bcrypt
BCRYPT_SALT_ROUNDS=12

# Porta do servidor (opcional, padrão 3001)
# PORT=3001
